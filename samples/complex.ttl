@prefix ex: <http://example.org/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

##################################################
# 1. Base + Relative IRIs
##################################################

@base <http://example.org/base/> .

<relative> ex:p <other> .
ex:iriTest ex:link <relative/path> .

##################################################
# 2. Predicate / Object Lists
##################################################

ex:john ex:name "John" ;
        ex:age 42 ;
        ex:city "Seattle" .

ex:john ex:knows ex:jane , ex:bob , ex:alice .

##################################################
# 3. Literals (all forms)
##################################################

ex:litSample ex:int 42 .
ex:litSample ex:decimal 3.14 .
ex:litSample ex:double 1.2e3 .

ex:litSample ex:flag true .
ex:litSample ex:flag false .

ex:litSample ex:label "color"@en-US .
ex:litSample ex:date "2026-04-27"^^xsd:date .

##################################################
# 4. String Edge Cases
##################################################

ex:strSample ex:text "Line1\nLine2\tTabbed" .
ex:strSample ex:text "He said \"Hello\"" .

ex:strSample ex:doc """This is
a multi-line
string""" .

##################################################
# 5. Blank Nodes
##################################################

# Inline blank node
ex:resident ex:address [
    ex:street "123 Main St" ;
    ex:city "Seattle"
] .

# Nested blank nodes
ex:employee ex:profile [
    ex:name "Carol" ;
    ex:contact [
        ex:email "carol@example.org" ;
        ex:phone "555"
    ]
] .

# Shared blank node
_:b1 ex:name "Shared" .
ex:node1 ex:link _:b1 .
ex:node2 ex:link _:b1 .

##################################################
# 6. RDF Collections (lists)
##################################################

ex:hobbyist ex:hobbies ( ex:reading ex:coding ex:hiking ) .

ex:listDemo ex:data ( ex:p1 ( ex:p2 ex:p3 ) ex:p4 ) .

##################################################
# 7. Empty structures
##################################################

ex:emptySample ex:empty [ ] .
ex:emptySample ex:list () .

##################################################
# 8. RDF Reification (standard)
##################################################

ex:stmt rdf:subject ex:john ;
        rdf:predicate ex:knows ;
        rdf:object ex:jane ;
        ex:confidence 0.9 .

##################################################
# 9. SHACL Shapes
##################################################

# Basic shape
ex:PersonShape a sh:NodeShape ;
    sh:targetClass ex:Person ;
    sh:property [
        sh:path ex:name ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] .

# Multiple properties
ex:PersonShape2 a sh:NodeShape ;
    sh:targetClass ex:Person ;
    sh:property [
        sh:path ex:age ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
    ] ;
    sh:property [
        sh:path ex:email ;
        sh:pattern "^[^@]+@[^@]+$" ;
    ] .

# Nested shapes
ex:ComplexShape a sh:NodeShape ;
    sh:targetClass ex:Person ;
    sh:property [
        sh:path ex:address ;
        sh:node [
            sh:property [
                sh:path ex:street ;
                sh:minCount 1 ;
            ] ;
            sh:property [
                sh:path ex:city ;
                sh:minCount 1 ;
            ]
        ]
    ] .

# SHACL list constraint
ex:ListShape a sh:NodeShape ;
    sh:property [
        sh:path ex:hobbies ;
        sh:in ( ex:reading ex:coding ex:hiking )
    ] .

##################################################
# 10. Mixed Complex Structures
##################################################

# Blank node + list
ex:mixedSample ex:data [
    ex:list ( ex:item1 ex:item2 ex:item3 )
] .

# Deep nesting
ex:deepSample ex:complex [
    ex:level1 [
        ex:level2 ( ex:val1 ex:val2 )
    ]
] .

ex:nodeList ex:data (
    [ ex:name "Alice" ]
    [ ex:name "Bob" ]
) .
